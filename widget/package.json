{
  "name": "onyx-chat-widget",
  "version": "1.0.0",
  "description": "Embeddable chat widget for Onyx",
  "type": "module",
  "main": "dist/onyx-widget.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "sync-logo": "node scripts/sync-logo.mjs",
    "dev": "vite",
    "prebuild": "npm run sync-logo",
    "build": "vite build",
    "prebuild:cloud": "npm run sync-logo",
    "build:cloud": "vite build --mode production",
    "prebuild:self-hosted": "npm run sync-logo",
    "build:self-hosted": "vite build --mode self-hosted",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "verify": "node scripts/verify-logo.mjs"
  },
  "dependencies": {
    "dompurify": "^3.3.2",
    "lit": "^3.1.0",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.0",
    "@types/node": "^20.0.0",
    "terser": "^5.46.1",
    "typescript": "^5.3.0",
    "vite": "^7.3.1"
  }
}
